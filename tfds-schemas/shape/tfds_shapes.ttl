gax-validation:InfrastructureOfferingShape a sh:NodeShape ;
    sh:property [ skos:example "'(a structure object of type InfrastructureProperties'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
