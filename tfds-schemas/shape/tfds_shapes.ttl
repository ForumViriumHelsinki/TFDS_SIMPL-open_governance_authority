gax-validation:ApplicationPropertiesShape a sh:NodeShape ;
    sh:property [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Application package" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "package" ;
            sh:order 1 ;
            sh:path simpl:package ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'www.gx.com'" ;
            sh:datatype xsd:anyURI ;
            sh:description "Application link" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "link" ;
            sh:order 2 ;
            sh:path simpl:link ;
            sh:pattern "^([Hh][Tt][Tt][Pp][Ss]?):\\/\\/(?:www\\.)?[A-Za-z0-9][-A-Za-z0-9@:%_\\+~#=\\.]{0,255}\\.[A-Za-z0-9()]{1,6}\\b(?:[-A-Za-z0-9()@:%_\\+.~#?&/=]*)$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'docker image, executable package'" ;
            sh:datatype xsd:anyURI ;
            sh:description "Format under which the application is distributed (e.g. docker image, executable package, ...). Might be more than one format available for the same application." ;
            sh:name "open api" ;
            sh:order 3 ;
            sh:path simpl:openApi ;
            sh:pattern "^([Hh][Tt][Tt][Pp][Ss]?):\\/\\/(?:www\\.)?[A-Za-z0-9][-A-Za-z0-9@:%_\\+~#=\\.]{0,255}\\.[A-Za-z0-9()]{1,6}\\b(?:[-A-Za-z0-9()@:%_\\+.~#?&/=]*)$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Target users" ;
            sh:name "target users" ;
            sh:order 4 ;
            sh:path simpl:targetUsers ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Requirements on the runtime environment (useful for the deployment in the infrastructure provider)" ;
            sh:name "requirements" ;
            sh:order 5 ;
            sh:path simpl:requirements ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'www.gx.com'" ;
            sh:datatype xsd:anyURI ;
            sh:description "URL of the documentation on how to use the application" ;
            sh:name "url" ;
            sh:order 6 ;
            sh:path simpl:url ;
            sh:pattern "^([Hh][Tt][Tt][Pp][Ss]?):\\/\\/(?:www\\.)?[A-Za-z0-9][-A-Za-z0-9@:%_\\+~#=\\.]{0,255}\\.[A-Za-z0-9()]{1,6}\\b(?:[-A-Za-z0-9()@:%_\\+.~#?&/=]*)$" ] ;
    sh:targetClass simpl:ApplicationProperties .

gax-validation:DataPropertiesShape a sh:NodeShape ;
    sh:property [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'http://provenanceURL.eu'" ;
            sh:datatype xsd:anyURI ;
            sh:description "Provenance" ;
            sh:maxCount 1 ;
            sh:name "produced by" ;
            sh:order 1 ;
            sh:path simpl:producedBy ;
            sh:pattern "^([Hh][Tt][Tt][Pp][Ss]?):\\/\\/(?:www\\.)?[A-Za-z0-9][-A-Za-z0-9@:%_\\+~#=\\.]{0,255}\\.[A-Za-z0-9()]{1,6}\\b(?:[-A-Za-z0-9()@:%_\\+.~#?&/=]*)$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'csv, xml'" ;
            sh:datatype xsd:string ;
            sh:description "Format under which the data is distributed (e.g. csv, xml, …)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "format" ;
            sh:order 2 ;
            sh:path simpl:format ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'http://mysite/swagger-ui/index.html'" ;
            sh:datatype xsd:anyURI ;
            sh:description "Schema of the dataset, depends on the type of data for JSON it would be JSON Schema Description that states what fields the data has and the types." ;
            sh:name "open api" ;
            sh:order 3 ;
            sh:path simpl:openApi ;
            sh:pattern "^([Hh][Tt][Tt][Pp][Ss]?):\\/\\/(?:www\\.)?[A-Za-z0-9][-A-Za-z0-9@:%_\\+~#=\\.]{0,255}\\.[A-Za-z0-9()]{1,6}\\b(?:[-A-Za-z0-9()@:%_\\+.~#?&/=]*)$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'http://mysite/swagger-ui/index.html'" ;
            sh:datatype xsd:anyURI ;
            sh:description "Additional Information about the dataset" ;
            sh:maxCount 1 ;
            sh:name "additional info" ;
            sh:order 4 ;
            sh:path simpl:additionalInfo ;
            sh:pattern "^([Hh][Tt][Tt][Pp][Ss]?):\\/\\/(?:www\\.)?[A-Za-z0-9][-A-Za-z0-9@:%_\\+~#=\\.]{0,255}\\.[A-Za-z0-9()]{1,6}\\b(?:[-A-Za-z0-9()@:%_\\+.~#?&/=]*)$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Related datasets" ;
            sh:name "related datasets" ;
            sh:order 5 ;
            sh:path simpl:relatedDatasets ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Target users" ;
            sh:name "target users" ;
            sh:order 6 ;
            sh:path simpl:targetUsers ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Data Quality (to include metrics such as completeness, accuracy, timeliness and other)" ;
            sh:name "data quality" ;
            sh:order 7 ;
            sh:path simpl:dataQuality ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Encryption: Describes the encryption algorithms and keys used to secure the data" ;
            sh:maxCount 1 ;
            sh:name "encryption" ;
            sh:order 8 ;
            sh:path simpl:encryption ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Anonymization/pseudonymization: Indicates whether sensitive information has been anonymized or pseudonymized to protect privacy" ;
            sh:maxCount 1 ;
            sh:name "anonymization" ;
            sh:order 9 ;
            sh:path simpl:anonymization ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ] ;
    sh:targetClass simpl:DataProperties .

gax-validation:InfrastructurePropertiesShape a sh:NodeShape ;
    sh:property [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Resource Type" ;
            sh:in ( "vm" "container" "block_storage" "object_storage" "relational_db" "document_db" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "resource type" ;
            sh:order 4 ;
            sh:path simpl:resourceType ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Region And Availability" ;
            sh:in ( "eu-west-1" "eu-west-2" "eu-west-3" "eu-central-1" "eu-north-1" "eu-south-1" "eu-south-2" ) ;
            sh:minCount 1 ;
            sh:name "region and az" ;
            sh:order 5 ;
            sh:path simpl:regionAndAz ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'10'" ;
            sh:datatype xsd:string ;
            sh:description "Size and Capacity" ;
            sh:maxCount 1 ;
            sh:name "size and cap" ;
            sh:order 6 ;
            sh:path simpl:sizeAndCap ;
            sh:pattern "\\d+(\\.\\d+)?\\s?(B|KB|MB|GB|TB|PB|EB|ZB|YB)" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Operating System and Image" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "os and image" ;
            sh:order 7 ;
            sh:path simpl:osAndImage ;
            sh:pattern "^(.|\\s)*[a-zA-Z]+(.|\\s)*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Network Configuration" ;
            sh:maxCount 1 ;
            sh:name "network configuration" ;
            sh:order 8 ;
            sh:path simpl:networkConfiguration ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Security Settings" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "security settings" ;
            sh:order 9 ;
            sh:path simpl:securitySettings ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Instance Type" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "instance type" ;
            sh:order 10 ;
            sh:path simpl:instanceType ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Storage Type" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "storage type" ;
            sh:order 11 ;
            sh:path simpl:storageType ;
            sh:pattern "^[a-zA-Z0-9][a-zA-Z0-9\\s]*$" ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Backup And Redundancy" ;
            sh:in ( "full-backup" "incremental-backup" "differential-backup" ) ;
            sh:maxCount 1 ;
            sh:name "backup" ;
            sh:order 12 ;
            sh:path simpl:backup ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Scalability Options" ;
            sh:in ( "dynamic-scaling" "scheduled-scaling" "sharding" ) ;
            sh:maxCount 1 ;
            sh:name "scalability" ;
            sh:order 13 ;
            sh:path simpl:scalability ],
        [ simpl:configure ( "useForAdvancedSearch" ) ;
            skos:example "'Text'" ;
            sh:datatype xsd:string ;
            sh:description "Monitoring and Logging" ;
            sh:maxCount 1 ;
            sh:name "monitoring" ;
