        [ skos:example "'(a structure object of type AssetProperties'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "asset properties" ;
            sh:node gax-validation:AssetPropertiesShape ;
            sh:order 2 ;
            sh:path simpl:assetProperties ],
        [ skos:example "'(a structure object of type ProviderInformation'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "provider information" ;
