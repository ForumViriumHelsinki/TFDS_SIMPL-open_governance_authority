# ==============================================================================
# TFDS Extended Shapes
# 
# This file EXTENDS the default SIMPL shapes (sdtooling-sd-schemas release v1.11.0).
# The TFDS-specific definitions are placed at the beginning of this file to accommodate
# the requirements set by the D2.3 report. The default SIMPL shapes follow below.
#
# TFDS Namespace: https://trafficflowdataspace.eu/ontology#
# ==============================================================================

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix tfds: <https://trafficflowdataspace.eu/ontology#> .
@prefix simpl: <https://w3id.org/simpl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ----------------------------------------------------------------------
# TFDS SHACL Validation Shapes
# ----------------------------------------------------------------------

tfds:TrafficFlowDataOfferingShape a sh:NodeShape ;
    sh:targetClass tfds:TrafficFlowDataOffering ;
    
    # Enforce DATEX II Compliance
    sh:property [
        sh:path dcterms:conformsTo ;
        sh:hasValue <https://datex2.eu/> ;
        sh:message "TFDS Violation: Traffic Flow Data Offerings MUST conform to the DATEX II standard (https://datex2.eu/)." ;
    ] ;
    
    # Enforce ODRL Policy Requirement
    sh:property [
        sh:path odrl:hasPolicy ;
        sh:minCount 1 ;
        sh:message "TFDS Violation: All Data Offerings MUST include a machine-readable ODRL usage policy." ;
    ] .

tfds:TrafficDisturbanceDataOfferingShape a sh:NodeShape ;
    sh:targetClass tfds:TrafficDisturbanceDataOffering ;
    
    # Enforce DATEX II Compliance
    sh:property [
        sh:path dcterms:conformsTo ;
        sh:hasValue <https://datex2.eu/> ;
        sh:message "TFDS Violation: Traffic Disturbance Data Offerings MUST conform to the DATEX II standard (https://datex2.eu/)." ;
    ] ;
    
    # Enforce ODRL Policy Requirement
    sh:property [
        sh:path odrl:hasPolicy ;
        sh:minCount 1 ;
        sh:message "TFDS Violation: All Data Offerings MUST include a machine-readable ODRL usage policy." ;
    ] .

tfds:IdeaValidationDataOfferingShape a sh:NodeShape ;
    sh:targetClass tfds:IdeaValidationDataOffering ;
    
    # Enforce DATEX II Compliance
    sh:property [
        sh:path dcterms:conformsTo ;
        sh:hasValue <https://datex2.eu/> ;
        sh:message "TFDS Violation: IDEA Validation Data Offerings MUST conform to the DATEX II standard (https://datex2.eu/)." ;
    ] ;
    
    # Enforce ODRL Policy Requirement
    sh:property [
        sh:path odrl:hasPolicy ;
        sh:minCount 1 ;
        sh:message "TFDS Violation: All Data Offerings MUST include a machine-readable ODRL usage policy." ;
    ] .

tfds:AirQualityDataOfferingShape a sh:NodeShape ;
    sh:targetClass tfds:AirQualityDataOffering ;
    
    # Enforce FIWARE Smart Data Models Compliance
    sh:property [
        sh:path dcterms:conformsTo ;
        sh:hasValue <https://smartdatamodels.org/> ;
        sh:message "TFDS Violation: Air Quality Data Offerings MUST conform to the FIWARE Smart Data Models (https://smartdatamodels.org/)." ;
    ] ;
    
    # Enforce ODRL Policy Requirement
    sh:property [
        sh:path odrl:hasPolicy ;
        sh:minCount 1 ;
        sh:message "TFDS Violation: All Data Offerings MUST include a machine-readable ODRL usage policy." ;
    ] .

# ==============================================================================
# DEFAULT SIMPL SHAPES (v1.11.0) BEGIN HERE
# ==============================================================================

@prefix gax-validation: <http://w3id.org/gaia-x/validation#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix simpl: <http://w3id.org/gaia-x/simpl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

gax-validation:ApplicationOfferingShape a sh:NodeShape ;
    sh:property [ skos:example "'(a structure object of type ApplicationProperties'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "application properties" ;
            sh:node gax-validation:ApplicationPropertiesShape ;
            sh:order 1 ;
            sh:path simpl:applicationProperties ],
        [ skos:example "'(a structure object of type ServicePolicy'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "service policy" ;
            sh:node gax-validation:ServicePolicyShape ;
            sh:order 5 ;
            sh:path simpl:servicePolicy ],
        [ skos:example "'(a structure object of type ContractTemplate'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "contract template" ;
            sh:node gax-validation:ContractTemplateShape ;
            sh:order 6 ;
            sh:path simpl:contractTemplate ],
        [ simpl:configure ( "hiddenInFrontend" ) ;
            skos:example "'(a structure object of type EdcRegistration'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "edc registration" ;
            sh:node gax-validation:EdcRegistrationShape ;
            sh:order 7 ;
            sh:path simpl:edcRegistration ],
        [ simpl:configure ( "hiddenInFrontend" ) ;
            skos:example "'(a structure object of type EdcConnector'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "edc connector" ;
            sh:node gax-validation:EdcConnectorShape ;
            sh:order 8 ;
            sh:path simpl:edcConnector ],
        [ skos:example "'(a structure object of type GeneralServiceProperties'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "general service properties" ;
            sh:node gax-validation:GeneralServicePropertiesShape ;
            sh:order 1 ;
            sh:path simpl:generalServiceProperties ],
        [ skos:example "'(a structure object of type AssetProperties'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "asset properties" ;
            sh:node gax-validation:AssetPropertiesShape ;
            sh:order 2 ;
            sh:path simpl:assetProperties ],
        [ skos:example "'(a structure object of type ProviderInformation'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "provider information" ;
            sh:node gax-validation:ProviderInformationShape ;
            sh:order 3 ;
            sh:path simpl:providerInformation ],
        [ skos:example "'(a structure object of type OfferingPrice'" ;
            sh:description "Basic classification of the service as per provision type and service model." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:name "offering price" ;
            sh:node gax-validation:OfferingPriceShape ;
            sh:order 4 ;
            sh:path simpl:offeringPrice ] ;
    sh:targetClass simpl:ApplicationOffering .

